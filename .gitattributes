# Normalize line endings so Windows/macOS/Linux collaborators don't see
# phantom whole-file diffs (a common cause of avoidable merge conflicts).
* text=auto eol=lf

# Explicit text types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Generated lock file: keep diffs collapsed in reviews and reduce noise.
package-lock.json linguist-generated=true

# Binary assets — never try to merge or normalize these
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.pt   binary
*.pth  binary
