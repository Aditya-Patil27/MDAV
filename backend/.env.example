DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mdav
JWT_SECRET=mdav-dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
STORAGE_PATH=./storage
# Trained weights (see doctamper.ipynb / Untitled5.ipynb). In Docker these are
# mounted under /app/models; locally point them at the repo-root files.
MDAV_VISION_WEIGHTS=./models/best.pth
MDAV_LAYOUT_WEIGHTS=./models/best_layout_detector.pt
MDAV_LAYOUT_CONF=0.40
# AI-generated forgery branch: a HF image-classifier. Point at the local folder
# holding model.safetensors + config.json + preprocessor_config.json (see
# models/diffusion/README.md), or an HF model id to auto-download instead.
MDAV_DIFFUSION_MODEL=./models/diffusion
# Optional UIDAI cert (PEM) to cryptographically verify the Aadhaar Secure QR.
# MDAV_UIDAI_CERT=./certs/uidai.pem
# Optional dir for tamper heatmaps (defaults next to the uploaded file).
# HEATMAP_DIR=./storage/heatmaps
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
