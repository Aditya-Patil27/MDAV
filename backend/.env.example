DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mdav
JWT_SECRET=mdav-dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
STORAGE_PATH=./storage
# Trained weights. Docker mounts them under /app/models; these relative paths
# assume the documented local command is run from backend/.
MDAV_VISION_WEIGHTS=../models/best.pth
MDAV_LAYOUT_WEIGHTS=../models/best_layout_detector.pt
MDAV_LAYOUT_CONF=0.40
# Preferred AIForge backend: local DCT+RGB segmentation checkpoint.
MDAV_DIFFUSION_WEIGHTS=../models/best_diffusion.pth
MDAV_DIFFUSION_THRESHOLD=0.95
# A segmentation map must contain a coherent threshold-crossing region before
# it contributes forged evidence. These are conservative cold-start defaults.
MDAV_DIFFUSION_MIN_COMPONENT_PIXELS=16
MDAV_VISUAL_PIXEL_THRESHOLD=0.80
MDAV_VISUAL_MIN_COMPONENT_PIXELS=16
# AIForge and DocTamper require identity-document calibration. Until a labelled
# Aadhaar/PAN evaluation set is available, cap their committed confidence here.
MDAV_IDENTITY_FORENSICS_CONFIDENCE_CAP=0.25
# Optional explicit Hugging Face classifier fallback. No classifier is downloaded
# unless this variable is set and the segmentation checkpoint cannot be loaded.
# MDAV_DIFFUSION_MODEL=../models/diffusion
# Optional UIDAI cert (PEM) to cryptographically verify the Aadhaar Secure QR.
# MDAV_UIDAI_CERT=./certs/uidai.pem
# Optional dir for tamper heatmaps (defaults next to the uploaded file).
# HEATMAP_DIR=./storage/heatmaps
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
